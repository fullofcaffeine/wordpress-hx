-cp ../haxe.compilerdev.reference/reflaxe/src
-cp src
-cp fixtures/php-facade/src
-cp fixtures/wphx-php/src
-main wphx.fixtures.compiler.php.facade.F1Entry
-D wphx_php_output=build/wphx-php/f1/generated
-D wphx_php_manifest=build/wphx-php/f1/generated/wphx-php-emission.v1.json
